{
    "name": "nisarg24/laravel-agent-board",
    "description": "A Laravel package that integrates JIRA and Confluence with an AI agent system to automate task completion and display a live Kanban dashboard.",
    "type": "library",
    "license": "MIT",
    "keywords": [
        "laravel",
        "laravel-12",
        "jira",
        "confluence",
        "ai",
        "kanban",
        "automation",
        "task-management",
        "ai-agents",
        "openai",
        "anthropic"
    ],
    "authors": [
        {
            "name": "Nisarg",
            "email": "nisarg24@github.com",
            "homepage": "https://github.com/nisarg24/laravel-agent-board"
        }
    ],
    "require": {
        "php": "^8.2",
        "guzzlehttp/guzzle": "^7.0",
        "illuminate/bus": "^12.0",
        "illuminate/cache": "^12.0",
        "illuminate/console": "^12.0",
        "illuminate/contracts": "^12.0",
        "illuminate/database": "^12.0",
        "illuminate/events": "^12.0",
        "illuminate/filesystem": "^12.0",
        "illuminate/queue": "^12.0",
        "illuminate/routing": "^12.0",
        "illuminate/support": "^12.0",
        "illuminate/view": "^12.0",
        "openai-php/client": "^0.10"
    },
    "require-dev": {
        "larastan/larastan": "^3.0",
        "laravel/framework": "^12.0",
        "laravel/pint": "^1.0",
        "mockery/mockery": "^1.6",
        "orchestra/testbench": "^10.0",
        "phpstan/phpstan": "^2.0",
        "phpstan/phpstan-strict-rules": "^2.0",
        "phpunit/phpunit": "^12.0"
    },
    "autoload": {
        "psr-4": {
            "DevBridge\\AgentBoard\\": "src/"
        }
    },
    "autoload-dev": {
        "psr-4": {
            "DevBridge\\AgentBoard\\Tests\\": "tests/"
        }
    },
    "extra": {
        "laravel": {
            "providers": [
                "DevBridge\\AgentBoard\\AgentBoardServiceProvider"
            ],
            "aliases": {
                "AgentBoard": "DevBridge\\AgentBoard\\Facades\\AgentBoard"
            }
        }
    },
    "config": {
        "sort-packages": true,
        "allow-plugins": {
            "composer/package-versions-deprecated": true,
            "php-http/discovery": true
        }
    },
    "minimum-stability": "stable",
    "prefer-stable": true
}
